<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Circuids.Pulse.Maui.Sample.MainPage"
             Title="Pulse Conformance">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label
                Text="Circuids.Pulse — MAUI sample"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Runs the Pulse conformance suites registered in MauiProgram inside the live MAUI host — using the real DI graph and real platform services this app is using right now."
                Style="{StaticResource SubHeadline}" />

            <Button
                x:Name="RunButton"
                Text="Run conformance"
                Clicked="OnRunClicked"
                HorizontalOptions="Fill" />

            <Label x:Name="SummaryLabel" FontAttributes="Bold" />

            <Label x:Name="EnvironmentLabel" FontSize="12" />

            <CollectionView x:Name="ResultsView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,6" ColumnDefinitions="80,*,90"
                              ColumnSpacing="8" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Outcome}"
                                   FontAttributes="Bold" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TestName}" />
                            <Label Grid.Row="0" Grid.Column="2"
                                   HorizontalTextAlignment="End"
                                   Text="{Binding DurationText}" />
                            <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding Message}"
                                   FontSize="11"
                                   IsVisible="{Binding HasMessage}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
